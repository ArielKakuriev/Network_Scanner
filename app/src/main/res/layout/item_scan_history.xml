<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivHistoryIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/colorSecondaryContainer"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_recent_history"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorOnSecondaryContainer" />

        <TextView
            android:id="@+id/tvNetworkName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Home Wi-Fi"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            app:layout_constraintEnd_toStartOf="@id/tvDeviceCount"
            app:layout_constraintStart_toEndOf="@id/ivHistoryIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvScanDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="October 24, 2023 - 14:30"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:alpha="0.7"
            app:layout_constraintEnd_toStartOf="@id/tvDeviceCount"
            app:layout_constraintStart_toStartOf="@id/tvNetworkName"
            app:layout_constraintTop_toBottomOf="@id/tvNetworkName" />

        <TextView
            android:id="@+id/tvDeviceCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/colorPrimaryContainer"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="12 Devices"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorOnPrimaryContainer"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
