<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NetworkScanner" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorError">@color/error</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.NetworkScanner.Splash" parent="Theme.NetworkScanner">
        <item name="android:windowBackground">@color/primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <style name="Theme.NetworkScanner.NoActionBar" parent="Theme.NetworkScanner">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Card style -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <!-- Section header text -->
    <style name="SectionHeader">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Value text -->
    <style name="ValueText">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
